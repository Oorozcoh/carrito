
<h1>Catálogo de Productos en Tiempo Real (WebSockets)</h1>
<p>Filtrado dinámico e interactivo con categorías autogeneradas.</p>
<hr>

<div style="margin-bottom: 20px;">
    <label for="categorySelect" style="font-weight: bold; margin-right: 10px;">Filtrar por Categoría:</label>
    <select id="categorySelect" style="padding: 8px; border-radius: 4px; border: 1px solid #ccc; font-size: 16px;">
        <option value="todos">Mostrar Todos</option>
    </select>
</div>

<div id="productsContainer" class="grid">
    </div>

<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();
    const container = document.getElementById('productsContainer');
    const categorySelect = document.getElementById('categorySelect');

    socket.on('updateProductsAndCategories', (data) => {
        const { products, categories } = data;

        const currentSelection = categorySelect.value;

        categorySelect.innerHTML = '<option value="todos">Mostrar Todos</option>';

        categories.forEach(cat => {
            const option = document.createElement('option');
            option.value = cat;
            option.textContent = cat.charAt(0).toUpperCase() + cat.slice(1);
            categorySelect.appendChild(option);
        });

        if (categories.includes(currentSelection)) {
            categorySelect.value = currentSelection;
        } else {
            categorySelect.value = 'todos';
        }

        container.innerHTML = '';

        if (products.length === 0) {
            container.innerHTML = '<p style="grid-column: 1/-1; color: #666;">No se encontraron productos.</p>';
            return;
        }

        products.forEach(prod => {
            const card = document.createElement('div');
            card.className = 'card';
            card.innerHTML = `
                <h3>${prod.title}</h3>
                <p>${prod.description}</p>
                <p><strong>Precio:</strong> $${prod.price}</p>
                <p><small>ID: ${prod.id} | Categoría: <strong>${prod.category}</strong></small></p>
            `;
            container.appendChild(card);
        });
    });

    // Detectar cambios en el menú select
    categorySelect.addEventListener('change', (e) => {
        socket.emit('filterCategory', e.target.value);
    });
</script>